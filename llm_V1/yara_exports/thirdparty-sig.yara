md5 = "e2d2884869f48f40b32fb27cc3bdefff"
	strings:
    $x1 = { ?? 14 40 B9 ?? B0 1D 11 ?? 10 40 B9 [5] 0C 40 B9 [5] 1F 80 52 [9] 1F 00 12 }

