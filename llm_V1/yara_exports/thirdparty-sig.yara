        uint16(0) == 0x5a4d and (5 of ($f*) or 5 of ($s*) or (4 of ($f*) and 2 of ($s*) or (all of ($m*) and 3 of them)) or 8 of them)
}


rule Win32_Trojan_PROMETHIUM_125083 
 {
	meta:
		sigid = 125083
		date = "2022-02-09 02:12 AM"
		threatname = "Win32.Trojan.PROMETHIUM"
		category = "Malware & Botnet"
		risk = 0
		author = "MKelly, Insikt Group, Recorded Future"
date = "2020-02-03"
description = "Detecting StrongPity spyware samples described in Insikt Group reporting using common strings"
version = "1.0"
reference = "https://support.recordedfuture.com/hc/en-us/articles/360042886114"
hash = "c790e1916a475fbc18e7f239acf0d9399234cf2160529ba25ab44179674d549a"
hash = "acc05f416b4d219e7678afea36abd1fbcde6aea87489138fc9cf881dfacb2ebb"
hash = "d8d0c3854c54e2bacb40ead54d94268dda6ea6aef1ac1f78b8d10b990a4441a2"
	strings:
    $x1 = "cmd.exe /C ping 6.6.3.3 -n 5 " fullword wide
    $x2 = "cmd.exe /C ping 2.4.4.5 -n 3 -w 3450" fullword ascii
    $x3 = "name=%ls&delete=WinHttpWriteDataWinHttpQueryHeadWinHttpCloseHandWinHttpReceiveReWinHttpOpenRequeWinHttpQueryOptiWinHttpSetOption" ascii
    $n1 = "spoolsrv32.exe" fullword wide
    $n2 = "SecurityHealthHost.exe" fullword wide
    $n3 = "wsutil32.exe" fullword wide
    $n4 = "rundll32.exe" fullword wide
    $n5 = "dpserver.exe" fullword wide
    $n6 = "dunstask.exe" fullword wide
    $n7 = "ngentask.exe" fullword wide
condition:
    uint16 (0) == 0x5a4d
    and 1 of ($x*) and 1 of ($n*)
    and filesize <= 200KB
    and pe.sections[3].name == ".gfids"
}


