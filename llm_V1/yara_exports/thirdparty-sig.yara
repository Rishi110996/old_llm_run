		risk = 50
		author = "Mandiant"

description = "Rule looks for strings present in SigLoader (Native)"

md5 = "a3ccc48db9eabfed7245ad6e3a5b203f"
	strings:

$s1 = "[*]: Basic Loader..." ascii wide

