rule Win32_Trojan_PROMETHIUM_125078 
 {
	meta:
		sigid = 125078
		date = "2022-02-09 02:06 AM"
		threatname = "Win32.Trojan.PROMETHIUM"
		category = "Malware & Botnet"
		risk = 0
		author = "GLES, Insikt Group, Recorded Future"
date = "2020-06-29"
description = "Track a packet forwarding tool called PyxisNautica, likely for MiTM, linked to StrongPity"
version = "1.0"
reference = "https://support.recordedfuture.com/hc/en-us/articles/360042886114"
reference = "https://www.bitdefender.com/files/News/CaseStudies/study/353/Bitdefender-Whitepaper-StrongPity-APT.pdf"
reference = "https://blog.talosintelligence.com/2020/06/promethium-extends-with-strongpity3.html"
hash = "84942df440c892c1e63aff41d9fe4694ea4b8a9102c62faf07c4510671abef13"
	strings:
    $s1 = "d:\\agent\\_work\\4\\s\\src\\vctools\\crt\\crtw32\\stdhpp\\xstring" ascii wide
    $s2 = "ether proto 0x8955 and not ether broadcast and not ether src %02x:%02x:%02x:%02x:%02x:%02x" ascii wide
    $s3 = "rpcap://" ascii wide
    $s4 = "Error in pcap_findalldevs_ex: %s" ascii wide
condition:
    uint16 ( 0 ) == 0x5a4d
    and (2 of them
    and (pe.imphash() == "57a89a6c5a08a38d52c294f0cd716357"
    or pe.rich_signature.key == 0x7B92B55A))
}

rule Win32_Trojan_OceanLotus_125077 
 {
	meta:
		sigid = 125077
		date = "2022-03-02 11:59 AM"
		threatname = "Win32.Trojan.OceanLotus"
		category = "Malware & Botnet"
		risk = 0
		description = "Identifies a backdoor from a malicious campaign identified by Netskope Threat Labs"
reference = "f35ce827885711a49f7fa0f884cff05460bb3f582810b10beb06ceff57eda547"
	strings:
	$aes_seq = { 63 7C 77 7B F2 6B 6F C5 30 01 67 2B FE D7 AB 76 CA 82 C9 7D FA 59 47 F0 AD D4 A2 AF 9C A4 72 C0 }

	// Loop sequence, based on 0x10044177
	$asm_00 = { 66 8b ?? 83 c? 02 66 85 ?? 75 ?? 2b ??  }

	$api00 = "EnumProcesses"
	$api01 = "SHGetFolderPathW"
	$api02 = "SHCreateDirectoryExW"
	$api03 = "ObtainUserAgentString"
	$api04 = "GetAdaptersInfo"
	$api05 = "GetUserNameW"
	$api06 = "GetComputerNameExW"

	$str00 = "User:" wide nocase
	$str01 = "Computer:" wide nocase
	$str02 = "<DIR>" wide nocase
	$str03 = "properties.bin" wide nocase
	$str04 = "7zAES"
	$str05 = "LZMA"
	$str06 = "AES256CBC"
	$str07 = "BZip2"

condition:
	uint16(0) == 0x5a4d
	and $aes_seq
	and #asm_00 > 2
	and all of ($api*)
	and all of ($str*)
}

