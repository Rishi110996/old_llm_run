rule Win32_Trojan_PROMETHIUM_125082 
 {
	meta:
		sigid = 125082
		date = "2022-02-09 02:10 AM"
		threatname = "Win32.Trojan.PROMETHIUM"
		category = "Malware & Botnet"
		risk = 0
		author = "MKelly, Insikt Group, Recorded Future"
date = "2020-02-03"
description = "Detecting StrongPity spyware samples described in Insikt Group reporting using import hashes"
version = "1.0"
reference = "https://support.recordedfuture.com/hc/en-us/articles/360042886114"
hash = "c790e1916a475fbc18e7f239acf0d9399234cf2160529ba25ab44179674d549a"
hash = "acc05f416b4d219e7678afea36abd1fbcde6aea87489138fc9cf881dfacb2ebb"
	condition:
    uint16 (0) == 0x5a4d
    and (
        pe.imphash() == "b2bb1c926dc3fc14c6792a346b16d29b"
        or pe.imphash() == "b996e2c3977a7044670484c0428d059e"
        or pe.imphash() == "8abe3681c11e209ff85599f5e699bd77"
