}

rule JS_Downloader_SocGholish_125184 
 {
	meta:
		sigid = 125184
		date = "2022-03-02 11:59 AM"
		threatname = "JS.Downloader.SocGholish"
		category = "Malware & Botnet"
		risk = 100
		description = "Triggers on SocGholish JS files"    
author = "Nils Kuhnert"    
date = "2021-03-29"
	strings:    
$try = "try" ascii
    $s1 = "new ActiveXObject('Scripting.FileSystemObject');" ascii
    $s2 = "['DeleteFile']" ascii    $s3 = "['WScript']['ScriptFullName']" ascii
    $s4 = "['WScript']['Sleep'](1000)" ascii
    $s5 = "new ActiveXObject('MSXML2.XMLHTTP')" ascii
    $s6 = "this['eval']" ascii    $s7 = "String['fromCharCode']"
    $s8 = "2), 16)," ascii    $s9 = "= 103," ascii
    $s10 = "'00000000'" ascii
	condition:    
	$try in (0 .. 10) and filesize > 3KB and filesize < 5KB and 8 of ($s*)
}

