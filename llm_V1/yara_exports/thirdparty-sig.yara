  $a3 = "function dExec(zURL, myKey, xPE, xEntryP)" ascii wide
  $a4 = "var xCrypted = zzzz4(Rkey + keynow, not_unique) + keynow;" ascii wide
  $a5 = "tmp = 3988292384 ^ tmp >>> 1;"
  $a6 = "cNow !== 3377271179 && cNow !== 3106260013 &&"   

condition:  
  filesize < 1MB and (2 of ($a*))
}

