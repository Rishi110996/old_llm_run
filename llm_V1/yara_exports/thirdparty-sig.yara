	meta:
		sigid = 129173
		date = "2023-07-31 06:20 AM"
		threatname = "Win32.RAT.ROMCOM"
		category = "Malware & Botnet"
		risk = 100
		description = "Rule to detect implants used to target the NATO summit"
    author = "BlackBerry"
    disribution = "TLP:WHITE"
    version = "1.0"
    last_modified = "2023-07-14"
    has1_sha256 = "1a7bb878c826fe0ca9a0677ed072ee9a57a228a09ee02b3c5bd00f54f354930f"
	

strings:

    $domain = "finformservice.com" ascii wide fullword nocase

    $a1 = {}  // "OneDriveSrv.dll"
    $a2 = {6689842430020000B8630000006689842432020000B86F0000006689842434020000B86D0000006689842436020000B84C0000006689842438020000B861000000668984243A020000B875000000668984243C020000B86E000000668984243E020000B8630000006689842440020000B868000000668984244202000033C0} // "DcomLaunch"

condition:
    (uint16(0) == 0x5a4d) and (filesize < 1MB and ($domain and any of ($a*)))

}

