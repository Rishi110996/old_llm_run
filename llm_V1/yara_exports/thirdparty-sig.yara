rule ELF64_Backdoor_VirtualPita_126685 
 {
	meta:
		sigid = 126685
		date = "2022-11-08 07:58 AM"
		threatname = "ELF64.Backdoor.VirtualPita"
		category = "Malware & Botnet"
		risk = 60
