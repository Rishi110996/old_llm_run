		modified_date = "2024-12-03 17:28 PM"
		threatname = ""
		category = ""
		risk = 0
		hash="0f9b0f27ce9ab5382dc43cf8f243bd1e"
	strings:
$filetype="staticgen:filetype:xls"
$process=/processcreated:path:C:\\Program Files\\Microsoft Office\\.{1,55}\\MSOSYNC.EXE/
$blacklist="sigid:11004" fullword //Known Md5
$blacklist1="sigid:1318" fullword //Suspended mode signature
$blacklist2="sigid:154" fullword //Injects PE into windows application
$blacklist4="sigid:255" fullword //Uses schtasks.exe or at.exe to add and modify task schedules
$blacklistreg="processcreated:path:C:\\Windows\\System32\\regsvr32.exe"
$blacklistwsc="processcreated:path:C:\\Windows\\System32\\wscript.exe"
$blacklistmsh="processcreated:path:C:\\Windows\\SysWOW64\\mshta.exe"
$blacklistcs="processcreated:path:C:\\Windows\\System32\\cscript.exe"
$blacklistrege="processcreated:path:C:\\Windows\\System32\\reg.exe"
$blacklistcmd="processcreated:path:C:\\Windows\\System32\\cmd.exe"
$blacklistrun="processcreated:path:C:\\Windows\\System32\\rundll32.exe"
$blacklistpow="processcreated:path:C:\\Windows\\System32\\WindowsPowerShell"
$blacklistbit="processcreated:path:C:\\Windows\\System32\\bitsadmin.exe"
$blacklistasm=/processcreated:path:C:\\Windows\\Microsoft.NET\\Framework\\.{0,20}\\RegAsm.exe/
$blacklistsch="processcreated:path:C:\\Windows\\System32\\schtasks.exe"
$blacklistvss="processcreated:path:C:\\Windows\\System32\\vssadmin.exe"
$blacklistwmi="processcreated:path:C:\\Windows\\System32\\wbem\\WMIC.exe"
$blacklisttask="processcreated:path:C:\\Windows\\System32\\tasklist.exe"
$blacklistlIP="processcreated:path:C:\\Windows\\System32\\ipconfig.exe"
$blacklistwho="processcreated:path:C:\\Windows\\System32\\whoami.exe"
$blacklistsnort="sigid:879" fullword //Snort IDS Alert for network traffic
$blacklist10="sigid:243" fullword //Uses ipconfig to modify the Windows network settings
$blacklist11="sigid:361" fullword //Queries the IP of a very long unknown domain name
$blacklist12="sigid:325" fullword //Uses dynamic DNS services
$blacklistdns=/dnsquery:name:.{0,30}\.(xyz|top|club|tk|world|pw|cf|vip|red|space|pro)(\r|\n)/
$vtresults="vt_result:detection:av_engine:"
$vtresultsmicrosoft="vt_result:detection:av_engine:Microsoft"
$vtresultsnod32="vt_result:detection:av_engine:ESET-NOD32"
condition:
(not any of ($blacklist*)) and ($filetype and $process and not (#vtresults>5 or $vtresultsmicrosoft or $vtresultsnod32))
}

