rule Win64_Coinminer_Xmrig_127049 : knownmalwareDS 
 {
	meta:
		sigid = 127049
		date = "2024-08-23 12:30 PM"
		modified_date = "2024-08-22 13:04 PM"
		threatname = "Win64.Coinminer.Xmrig"
		category = "Malware & Botnet"
		risk = 0
		
	strings:
	$type = "staticgen:filetype:exe" fullword
	$str1 = "processcreated:path:C:\\Windows\\System32\\WindowsPowerShell\\"
	$str2 = /filedump:path:C:\\Users\\PJones\\AppData\\Local\\Temp\\.{1,15}\.bat/
	$str3 = /C:\\Windows\\system32\\cmd\.exe \/c (''|'|)C:\\Users\\PJones\\AppData\\Local\\Temp\\.{1,15}\.bat(''|'|)/
	$str4 = /schtasks  \/create \/f \/sc MINUTE \/mo 5 \/RL HIGHEST \/tn .{1,10} \/tr ('|)C:\\ProgramData.{1,20}.exe('|)/
	$str5 = "'powershell'  -Command Add-MpPreference -ExclusionPath 'C:\\ProgramData'"
	$str6 = "sc stop UsoSvc" nocase
	$str7 = "powercfg /x" nocase
	$str8 = "XMRig" nocase
	$str9 = "miners.com"
	$sid3 = "sigid:171" fullword    // Executable uses .NET runtime
	$sid4 = "sigid:888" fullword    // Queries sensitive processor information   
	$sid5 = "sigid:672" fullword    // Queries process information (via WMI Win32_Process)
	$sid6 = "sigid:337" fullword    // Queries the volume information

condition:
	$type and $str1 and (($str2 and $str3) or ($str4 and $str5)) and (($str6 and $str7) or ($str8 and $str9)) and $sid3 and $sid4 and $sid5 and $sid6
}

