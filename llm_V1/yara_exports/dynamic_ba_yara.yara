rule VBA_Msiexec_Clean_135246 : knownclean 
 {
	meta:
		sigid = 135246
		date = "2025-01-21 08:16 AM"
		modified_date = "2025-01-21 08:16 AM"
		threatname = ""
		category = ""
		risk = 0
		
	strings:
$file_type=/staticgen:filetype:(doc|xls|ppt|rtf|dot|xlt|xla|pps|pot)/

$sigid1 ="sigid:400" fullword //Drops PE files to the user root directory
$sigid2 ="sigid:11011" fullword //Drops and executes PE files under widows/system directory
$sigid3 ="sigid:11009" fullword //Drops PE files in application program directory but not started or loaded
$sigid4 ="sigid:99" fullword //Deletes files inside the windows folder
$sigid4b = "sigid:308" fullword //Drops PE files to the Windows directory
$process = "processcreated:path:C:\\Windows\\system32\\msiexec.exe" nocase

$delreg="processcreated:path:C:\\Windows\\System32\\regsvr32.exe"
$delwsc="processcreated:path:C:\\Windows\\System32\\wscript.exe"
$delmsh="processcreated:path:C:\\Windows\\SysWOW64\\mshta.exe"
$delcs="processcreated:path:C:\\Windows\\System32\\cscript.exe"
$delrege="processcreated:path:C:\\Windows\\System32\\reg.exe"
$delrun="processcreated:path:C:\\Windows\\System32\\rundll32.exe"
$delpow="processcreated:path:C:\\Windows\\System32\\WindowsPowerShell"
$delbit="processcreated:path:C:\\Windows\\System32\\bitsadmin.exe"
$delasm=/processcreated:path:C:\\Windows\\Microsoft.NET\\Framework\\.{0,20}\\RegAsm.exe/
$delsch="processcreated:path:C:\\Windows\\System32\\schtasks.exe"
$delvss="processcreated:path:C:\\Windows\\System32\\vssadmin.exe"
$delwmi="processcreated:path:C:\\Windows\\System32\\wbem\\WMIC.exe"
$deltask="processcreated:path:C:\\Windows\\System32\\tasklist.exe"
$dellIP="processcreated:path:C:\\Windows\\System32\\ipconfig.exe"
$delwho="processcreated:path:C:\\Windows\\System32\\whoami.exe"

$vtresults="vt_result:detection:av_engine:"

condition:
$file_type and not $vtresults and not (any of ($del*)) and $sigid1 and $sigid2 and $sigid3 and ($sigid4 or $sigid4b ) and $process
}

