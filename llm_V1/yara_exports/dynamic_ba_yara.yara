rule Win32_Banker_Emotet_120241 : knownmalwareDS 
 {
	meta:
		sigid = 120241
		date = "2024-02-23 11:11 AM"
		threatname = "Win32.Banker.Emotet"
		category = "Malware & Botnet"
		risk = 0
		
	strings:
$filetype = "staticgen:filetype:exe" fullword
 //POST /jPgZ7zuXkU HTTP/1.1 | POST 
$str1 = /:POST (\/[a-z0-9A-Z]{3,25}){1,7}\/? HTTP/ 

//Referer: http://59.110.18.236/jPgZ7zuXkU | Referer: http(s)://{ip}/{urlpath}
$str2 = /\x0d\x0aReferer: http:\/\/(\d{1,3}\.){3}\d{1,3}(\/[a-z0-9A-Z]{3,25}){1,7}/ 

//Host: 59.110.18.236:443 | Host {IP}
$str3 = /\x0d\x0aHost: (\d{1,3}\.){3}\d{1,3}/ 

$str4 = "memstring:string:RSA Signature Key"

$dnt_useragent = {44 4E 54 3A 20 31 0D 0A 55 73 65 72 2D 41 67 65 6E 74 3A 20 4D 6F 7A 69 6C 6C 61 2F 34 2E 30 20 28 63 6F 6D 70 61 74 69 62 6C 65 3B 20 4D 53 49 45 20 37 2E 30} //DNT: 1\r\nUser-Agent: Mozilla/4.0 (compatible; MSIE 7.0

$cmdline1 = "ted:cmdline:C:\\Windows\\System32\\svchost.exe -k NetworkService"

//processcreated:cmdline:--429f21de
$cmdline2 = /ted:cmdline:\-\-[a-z0-9]{8}/   

//$sig7021="sigid:7021"  fullword //Performs connections to IPs without corresponding DNS lookups
$dns="dnsquery:name"

condition:
$filetype and $cmdline1 and $cmdline2
and $str1 
and $str2 
and $str3 
and $str4 
and $dnt_useragent
and not $dns

// checks if referer ip and host ip are same
and uint32(@str2+18) == uint32(@str3+8) and uint32(@str2+22) == uint32(@str3+12) and uint32(@str2+26) == uint32(@str3+16)
}

