rule Win64_Riskware_Cymulation_133637 : knownmalware 
 {
	meta:
		sigid = 133637
		date = "2025-04-17 07:23 AM"
		modified_date = "2025-04-17 11:33 AM"
		threatname = "Win64.Riskware.Cymulation"
		category = "Malware & Botnet"
		risk = 0
		
	strings:

$file = /staticgen:filetype:(hta|doc|dll|exe|exe64|dll64)/ fullword

$log = "CreateFileW(path=c:\\programdata\\Cymulate\\Agent\\AttacksLog"
$filecreate = "CreateFileA(path=\\pipe\\"
$cymulateA = "cymulate" nocase
$sigid1 = "sigid:420" fullword // PE file does not import any functions
$sigid2 = "sigid:602" fullword // Launches a second explorer.exe instance

$cymulateB3 = "CymulateCredsSteal" nocase wide ascii
$cymulateB1 = "cymulateEDR" nocase wide ascii
$cymulateB2 = "CymulatedecodeBase64" nocase wide ascii
$cmd = "cmd.exe"
//$sigid1 = "sigid:400" fullword // Drops PE files to the user root directory

$cyma = "cym-" nocase

$cymb1= "\\CymulateStagelessMeterpreter.{0,4}exe" nocase // CymulateStagelessMeterpreter_64.exe
$cymb2= "\\CymulateStagelessMeterpreter.{0,4}pdb" nocase //CymulateStagelessMeterpreter.pdb
$cymb3= "\\cymulate\\edr" nocase

$cymc1= "cymulatestagelessmeterpreter.{0,4}exe" nocase // cymulatestagelessmeterpreter.exe
$cymc2= "CymulateExplorerDllInjector.{0,4}pdb" nocase // CymulateExplorerDllInjector_64.pdb
$cymc3= "sigid:400" //Drops PE files to the user root directory

condition:

$file and (  
( $log and  $filecreate and $cymulateA and (1 of ($sigid*)) )  or 
 ( $log and 2 of ($cymulateB*) and $cmd )  or
( ( $cyma and (1 of ($cymb*)) ) or ( 2 of ($cymc*)) )
)
}

