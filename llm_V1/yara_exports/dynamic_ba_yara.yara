		risk = 0
		
	
    strings:
        $file = /staticgen:filetype:doc/
		$mac_ip = "do shell script \"\"ifconfig \" + Interface + \" inet"
        $mac_id = "do shell script \"\"dscl . -read /Users/\" & User & \" RecordName"
        $win_domain = "WshShell.exec(\"whoami /upn\")"
        $format = "EncodeHex(sData As String, Optional HexPrefix As String = \"0x\") As String"
        $token1 = ".o3n.io"
        $token2 = "Trigger_Token"



	condition:
		$file and $mac_ip and $mac_id and $win_domain and $format and 1 of ($token*)

}

rule Win32_PWS_FormBook_132689 : knownmalware 
 {
	meta:
		sigid = 132689
		date = "2024-08-01 13:23 PM"
		modified_date = "2024-08-01 08:30 AM"
		threatname = "Win32.PWS.Formbook"
		category = "Malware & Botnet"
		risk = 0
		
	strings:
    $type="staticgen:filetype:exe"
    $s1="WebCredentials"
    $s2=/:memstring:string:C:\\Users\\PJones\\AppData\\Roaming\\Microsoft\\Windows\\Start Menu\\Programs\\Startup\\[A-z0-9]{4,12}.ini/
    $s3=":memstring:string:Software\\AutoIt"
    $s4="sigid:186" fullword //Maps a DLL or memory area into another process
    $s5="sigid:155" fullword //Queues an APC in another process thread injection
    $s6="sigid:218" fullword //Writes to foreign memory regions
    $s7="sigid:263" fullword //May try to detect the virtual machine to hinder analysis
    $s8="sigid:764" fullword //Binary is likely a compiled AutoIt script file
    $s9="sigid:231" fullword //Tries to harvest and steal browser information
    $s10="sigid:207" fullword //Posts data to web server
    $x9 = "sigid:1318" fullword //Creates a process in suspended mode (likely to inject code)
    $x10 = "sigid:296" fullword //May try to detect the Windows Explorer process
condition:
    $type and 8 of ($s*) and (($s9 and $s10) or ($x9 and $x10))
}

