rule Win32_Backdoor_SystemBC_120348 : knownmalwareDS 
 {
	meta:
		sigid = 120348
		date = "2024-02-23 11:12 AM"
		threatname = "Win32.Backdoor.SystemBC"
		category = "Malware & Botnet"
		risk = 0
		
	strings:
$filetype = /staticgen:filetype:(exe|dll)/ fullword 
//processcreated:cmdline:C:\ProgramData\vkemrd\hwfqw.exe start2
//processcreated:cmdline:C:\ProgramData\rmwc\vsjtqbl.exe start2
$proc = /dline:C:\\ProgramData\\.{4,50}\.exe start2/

//filedump:path:C:\Windows\Tasks\hwfqw.job
//filedump:path:C:\Windows\Tasks\vsjtqbl.job
$file = /th:C:\\Windows\\Tasks\\[a-zA-Z]{3,40}\.job/

//memstring:string:BEGINDATA
$data = "ing:BEGINDATA"

//memstring:string:HOST1:advertx15.xyz
//memstring:string:HOST2:spacex17.xyz
$host = /ing:HOST(1|2):/

//memstring:string:PORT1:4044
$port = /ing:PORT(1|2):/

// memstring:string:DNS1:5.132.191.104
// memstring:string:DNS2:92.163.33.248
// memstring:string:DNS3:206.189.120.27
$dns = /ing:DNS(1|2|3):/

//memstring:string:.opennic.glue
$opennic = "ng:.opennic.glue"

// memstring:string:TOR:U-
$tor1 = "ng:TOR:U-" 
//memstring:string:GET /tor/rendezvous2/%s HTTP/1.0
$tor2 = "ng:GET /tor/rendezvous2/%s HTTP/1.0"

//memstring:string:onion-key
$tor3 = "ng:onion-key"

// memstring:string:a2guard.exe
$a2guard = "ng:a2guard.exe"

//memstring:string:https://ip4.seeip.org
$seeip = "ng:https://ip4.seeip.org"

//memstring:string:-----BEGIN RSA PUBLIC KEY-----
$rsa = "ng:-----BEGIN RSA PUBLIC KEY-----"

condition:
$filetype and #host >= 2 and $port and #dns >= 2 
and ($proc or $file) and $data
and $seeip and $rsa
and (any of ($tor*) or $opennic or $a2guard)
}

rule VBA_Downloader_TA505_120162 : monitormode 
 {
	meta:
		sigid = 120162
		date = "2024-02-23 11:12 AM"
		threatname = "VBA.Downloader.TA505"
		category = "Malware & Botnet"
		risk = 100
		author = "Atinder | Sahil"
created_on = "21/05/2020"
Modified_on = "25/06/2020"
filetype = "doc"
type = "APT"
version = "1.0"
description = "This rule is to detect TA505 doc payloads"
	strings:
$file = /staticgen:filetype:(doc|xls)/ fullword 
//filedump:path:C:\Users\Paul Jones\AppData\Local\Temp\oleObject1.bin
$drop1 = /path:C:\\Users\\.{4,15}\\AppData\\Local\\Temp\\oleObject1.bin/  nocase

//filedump:path:C:\Users\PAULJO~1\AppData\Local\Temp\~$mplate_present.docx.zip                                             
$drop2 = /path:C:\\Users\\.{4,15}\\AppData\\Local\\Temp\\~?\$?[a-zA-Z0-9_]{3,15}\.(docx|xlsx|pptx)\.zip/     nocase                                                                                 

condition:
$file and $drop1 and $drop2
}

