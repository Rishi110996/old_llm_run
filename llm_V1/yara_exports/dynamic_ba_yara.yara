	meta:
		sigid = 133011
		date = "2024-08-05 10:13 AM"
		modified_date = "2024-08-05 08:24 AM"
		threatname = "Win32.PWS.Atlantida"
		category = "Malware & Botnet"
		risk = 0
		author = "satyam.s"
desc = "Detects Atlantida on basis of string capture"
	strings:
$ft = "staticgen:filetype:exe"
$txtfile1 = "All domain.txt"
$txtfile2 = "tome0Old.txt"
$txtfile3 = "BroweserInfo.txt"
$txtfile4 = "Passwords.txt"
$txtfile5 = "Log Information.txt"
$txtfile6 = "Chrome.txt"
$txtfile7 = "pingme.txt"
$steal1 = "\\AppData\\Roaming\\Binance"
$steal2 = "\\AppData\\Roaming\\Telegram Desktop"
$steal3 = "\\Chrome\\User Data\\Default\\Local Extension Settings"
$sigid1 = "sigid:1699" fullword  //Tries to steal Crypto Currency Wallets
$sigid2 = "sigid:227"  fullword //Found strings which match to known social media URLs
$sigid3 = "sigid:231"  fullword //Tries to harvest and steal browser information
$sigid4 = "sigid:232"  fullword //Tries to harvest and steal FTP login credentials
$sigid5 = "sigid:7038" fullword  //Found many strings related to Crypto-Wallets
condition:
$ft and
($txtfile1 and $txtfile2 and $txtfile3 and $txtfile4 and $txtfile5 and $txtfile6 and $txtfile7) 
and $steal1 and $steal2 and $steal3 
and $sigid1 and $sigid2 and $sigid3 and $sigid4 and $sigid5
}

rule VBA_PWS_CanaryStealer_132870 : knownmalwareDS 
