rule Win32_suspname_Clean_123758 : knownclean 
 {
	meta:
		sigid = 123758
		date = "2022-03-02 11:59 AM"
		threatname = ""
		category = ""
		risk = 0
		hash="393B670ED069E61422B7A6DE34989ABE"
	strings:
$type="staticgen:filetype:exe"
$thread="sigid:908" fullword //Contain thread delay
$crash="sigid:81" fullword //One or more processes crash
$largebinary="sigid:443" fullword //Stores large binary data
$sleep="sigid:871" fullword //Sample execution stops while process was sleeping (likely an evasion)
$susname="sigid:649" fullword //Initial sample is a PE file and has a suspicious name
$suspicioustime="sigid:234" fullword //Binary contains a suspicious time stamp
$detectedtcp="sigid:522" fullword //Detected TCP or UDP traffic on non-standard ports
$VT="sigid:11004" fullword
$dns="dnsquery:name:"
$snort="sigid:879" fullword //Snort signature
$IP="sigid:7021" fullword //Performs connections to IPs without corresponding DNS lookups
$suspended="sigid:1318" //suspended mode signature
$inject="sigid:154"
$download="sigid:127" fullword //Downloads files from web servers via HTTP
$harvest="sigid:231" fullword //Tries to harvest and steal browser information
condition:
($type and $crash and $thread and $suspicioustime and $largebinary and $sleep and $susname) and not ($detectedtcp or $VT or $dns or $snort or $IP or $suspended or $inject or $download or $harvest)
}

