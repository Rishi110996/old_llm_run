rule PS_641_Clean_139200 : knownclean40 
 {
	meta:
		sigid = 139200
		date = "2025-08-26 07:21 AM"
		modified_date = "2025-08-26 12:56 PM"
		threatname = ""
		category = ""
		risk = 0
		
	strings:
$type="staticgen:filetype:ps1" fullword
$id = "sigid:641" fullword  //Found a high number of Window / User specific system calls

$blacklistdump1="Cymulate" nocase
$blacklistdump2="Ransom" nocase
$blacklistwsc="processcreated:path:C:\\Windows\\System32\\wscript.exe"
$blacklistmsh="processcreated:path:C:\\Windows\\SysWOW64\\mshta.exe"
$blacklistwv="processcreated:path:C:\\Windows\\system32\\wevtutil.exe"
$blacklisttask="sigid:260" fullword	//Uses tasklist.exe to query information about running processes
$blacklistinfo="processcreated:C:\\Windows\\SysWOW64\\systeminfo.exe"
$blacklistdns= /dnsquery:name:.{0,50}\.(id|link|top|club|xyz|tk|world|pw|cf|vip|red|space|gq|ml)[\r\n]/
$blacklistIP="sigid:7021" fullword
$blacklistnonports="sigid:522" fullword
$blacklistmimi="sigid:1758" fullword //Invoke-Mimikatz Powershell script found
$blacklistinject="sigid:154" fullword //Injects a PE file into a foreign processes
$blackliststart="sigid:717" fullword
$blacklistnetsh="sigid:245" fullword
$blacklistVT="sigid:11004" fullword
$blacklistcmdtool="sigid:645" fullword
$blacklistlsdsdsstr1 = "All encrypted files for this computer has extension"
$blacklistldsdsdsdstr2 = "your data may have been stolen"
$blacklistldfdfdstr3 = "Do not try to recover your files without a decrypter program"
$blacklistlsss1 = "RansomWare-Exodus"
$blacklistHacktool2="DNSFailureThreshold"
$blacklistspotx="SpotX" 
$blacklist1737 = "sigid:1737"fullword //Queries port and connector information
$blacklistengine="vt_result:detection:av_engine:"
$ageVT=/vt_result:ageoffile:(1|2|3)days/
$noav="vt_result:detection:av_engine:"
condition:
not any of ($blacklist*) and $type and $id  and not $ageVT and not $noav
}

rule Win32_PWS_DarkCloud_139615 : monitormode 
 {
	meta:
		sigid = 139615
		date = "2025-08-25 11:15 AM"
		modified_date = "2025-08-25 16:27 PM"
		threatname = "Win32.PWS.DarkCloud"
		category = "Malware & Botnet"
		risk = 0
		
	strings:
    $a2 = "PwaHelperImpl@edge_pwahelper"
    $a1 = "msedge_elf.dll"

    $b1 = "sigid:11004" // Known MD5
    $b2 = "sigid:154" // Injects a PE file into a foreign processes
    $b3 = "sigid:2" // Allocates memory in foreign processes
    $b4 = "sigid:218" // Writes to foreign memory regions
    $b5 = "sigid:400" // Drops PE files to the user root directory
    $b6 = "sigid:587" // Drops PE files with a known system name
    $b7 = "sigid:862" // Potential malicious VBS script found
condition:
    2 of ($a*) and 5 of ($b*)
}

rule Win32_Backdoor_XenoRAT_139611 : monitormode 
 {
	meta:
		sigid = 139611
		date = "2025-08-25 08:11 AM"
		modified_date = "2025-08-25 16:22 PM"
		threatname = "Win32.Backdoor.XenoRAT"
		category = "Malware & Botnet"
		risk = 0
		
	strings:
	$str_xeno_rat_1 = "xeno rat" wide ascii nocase
	$str_xeno_rat_2 = "xeno_rat" wide ascii nocase
	$str_xeno_update_mgr = "XenoUpdateManager" wide ascii
	$str_nothingset = "nothingset" wide ascii
	$byte_enc_dec_pre = "/AppData/Roaming/XenoManager/"
        $scheduletask = "\"schtasks.exe\" /Create /TN \"RuntimeBroker.exe\" /XML"
        $sigid1 = "sigid:102874" fullword //Yara detected XenoRAT
        $sigid2 = "sigid:255" fullword //Uses schtasks.exe or at.exe to add and modify task schedules
        $sigid3 = "sigid:263" fullword //May try to detect the virtual machine to hinder analysis (VM artifact strings found in memory)
	$sigid4 = "sigid:200028" fullword //Contains long base64 encoded strings

condition:
        ($str_xeno_rat_1 or $str_xeno_rat_2 or $str_xeno_update_mgr or $str_nothingset or $byte_enc_dec_pre or $scheduletask)
    and $sigid1 and $sigid2 and $sigid3 and $sigid4
}

