rule Win32_Ransom_Agent_134260 : knownmalware20 
 {
	meta:
		sigid = 134260
		date = "2024-10-28 13:56 PM"
		modified_date = "2024-10-25 07:18 AM"
		threatname = "Win32.Ransom.Agent"
		category = "Malware & Botnet"
		risk = 0
		
	strings:
$file = /staticgen:filetype:(dll|exe|exe64|dll64)/
        $cmd1 = "cmd /c \"WMIC.exe shadowcopy delet\"" nocase
        $cmd2 = "vssadmin.exe Delete Shadows /all" nocase
        $cmd3 = "Delete Shadows /all" nocase
        $cmd4 = "/set {default} recoveryenabled no" nocase
        $cmd5 = "/set {default} bootstatuspolicy ignoreallfailures" nocase
        $cmd6 = "wmic SHADOWCOPY DELETE" nocase
        $cmd7 = "\\Microsoft\\Windows\\SystemRestore\\SR\" /disable" nocase
        $cmd8 = "resize shadowstorage /for=c: /on=c: /maxsize=" nocase
        $cmd9 = "shadowcopy where \"ID='%s'\" delete" nocase
        $cmd10 = "wmic.exe SHADOWCOPY /nointeractive"  nocase
        $cmd11 = "WMIC.exe shadowcopy delete"  nocase
        $cmd12 = "Win32_Shadowcopy | ForEach-Object {$_.Delete();}" nocase
        $delr = /del \/s \/f \/q(( [A-Za-z]:\\(\*\.|[Bb]ackup))(VHD|bac|bak|wbcat|bkf)?)+/ nocase
        $wp1 = "delete catalog -quiet" nocase
        $wp2 = "wbadmin delete backup" nocase
        $wp3 = "delete systemstatebackup"  nocase
$blacklist = "NCC Group PLC" nocase
    condition:
 $file and  ((2 of ($cmd*) or (1 of ($cmd*) and 1 of ($wp*)) or #delr > 4) or (4 of them))  and not $blacklist
}

