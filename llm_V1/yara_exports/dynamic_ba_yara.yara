rule Win64_Banker_Emotet_126801 : knownmalware 
 {
	meta:
		sigid = 126801
		date = "2024-02-23 11:12 AM"
		threatname = "Win64.Banker.Emotet"
		category = "Malware & Botnet"
		risk = 0
		hash1 = "43f71babe436c604d3ff347bc149ab9f"
	hash2 = "1d0b7080b8e6ba01f5f791a73c697201"
	hash3 = "621cc1e31a11af5015c2408540a5fb9a"
	hash4 = "ca82c5a9fd70ea30b77567d16d01e183"
	hash5 = "1e44640b5865f2c1051a5f22a3a843ce"
	hash6 = "57b8cc63f7637dae4c04137f5b36f543"
hash7 = "8079b54a0c76ba1fec822059aa22ea31"
	strings:
$file = /staticgen:filetype:(exe|dll)/ fullword 
		$key = /:C:\\Windows\\system32\\regsvr32.exe ('|")C:\\Windows\\system32\\.[a-zA-Z]{3,50}\\.[A-Za-z]{3,50}\.dll/
		$key2 = /:C:\\Windows\\SysWOW64\\regsvr32.exe \/s ('|")C:\\Windows\\SysWOW64\\.[a-zA-Z]{3,50}\\.[A-Za-z]{3,50}\.sid/
		$str1 = "sigid:7021" fullword //Performs connections to IPs without corresponding DNS lookups
		$str2 = "sigid:1649" fullword //Hides that the sample has been downloaded from the Internet
		$str3 = "sigid:606" fullword //System process connects to network
		$str4 = "sigid:7058" fullword //Uses secure TLS version
		$str6 = "sigid:308" fullword //Drops PE files to the Windows directory
		$sigid1 = "sigid:183" fullword //...Document: drops PE files
		$sigid2 = "sigid:181" fullword //...Document exploit detected
		$sigid3 = "sigid:217" fullword //...Registers a DLL
condition:
		$file and ($key or $key2) and $str1 and $str2 and $str6 and (($str3 and $str4) or ($sigid1 and $sigid2 and $sigid3))
}

