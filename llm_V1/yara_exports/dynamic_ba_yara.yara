$type=/staticgen:filetype:(doc|xls|ppt).{0,1}/

$blacklist="sigid:11004" fullword //Known Md5
$blacklist1="sigid:1318" fullword //Suspended mode signature
$blacklist2="sigid:154" fullword //Injects PE into windows application
$blacklist3="sigid:522" fullword //Detected TCP or UDP traffic on non-standard ports
$blacklist4="sigid:255" fullword //Uses schtasks.exe or at.exe to add and modify task schedules
$blacklistreg="processcreated:path:C:\\Windows\\SysWOW64\\regsvr32.exe"
$blacklistwsc="processcreated:path:C:\\Windows\\System32\\wscript.exe"

$blacklistmsh="processcreated:path:C:\\Windows\\SysWOW64\\mshta.exe"
$blacklistcs="processcreated:path:C:\\Windows\\System32\\cscript.exe"
$blacklistrege="processcreated:path:C:\\Windows\\System32\\reg.exe"
$blacklistcmd="processcreated:path:C:\\Windows\\System32\\cmd.exe"
$blacklistrun="processcreated:path:C:\\Windows\\System32\\rundll32.exe"
$blacklistpow="processcreated:path:C:\\Windows\\System32\\WindowsPowerShell"
$blacklistbit="processcreated:path:C:\\Windows\\System32\\bitsadmin.exe"
$blacklistasm=/processcreated:path:C:\\Windows\\Microsoft.NET\\Framework\\.{0,20}\\RegAsm.exe/
$blacklistsch="processcreated:path:C:\\Windows\\System32\\schtasks.exe"
$blacklistvss="processcreated:path:C:\\Windows\\System32\\vssadmin.exe"
$blacklistwmi="processcreated:path:C:\\Windows\\System32\\wbem\\WMIC.exe"
$blacklisttask="processcreated:path:C:\\Windows\\System32\\tasklist.exe"
$blacklistlIP="processcreated:path:C:\\Windows\\System32\\ipconfig.exe"
$blacklistwho="processcreated:path:C:\\Windows\\System32\\whoami.exe"
$blacklistsnort="sigid:879" fullword //Snort IDS Alert for network traffic
$blacklistdns1= /dnsquery:name:.{0,30}\.(link|top|club|xyz|tk|world|pw|cf|vip|red|space|gq|ml)/
$blacklist_equation="sigid:1686" //Office equation editor process drops PE file
condition:
(not any of ($blacklist*)) and ($sig and $sig1 and $type and $sig2)
}

rule Win32_Downloader_Guloader_129624 : knownmalwareDS 
 {
	meta:
		sigid = 129624
		date = "2024-10-03 12:13 PM"
		modified_date = "2024-10-03 08:08 AM"
		threatname = "Win32.Downloader.GuLoader"
		category = "Malware & Botnet"
		risk = 0
		md5v= "8d5434c907f431294ae173513f46c22c"
	
    strings:
        $ftype = "staticgen:filetype:exe"
        $s1 = /filecreated:path:C:\\Users\\.{1,10}\\AppData\\Local\\Temp\\.{1,20}\.tmp\\System.dll/
		$s2 = /fileopened:path:C:\\Users\\.{1,10}\\AppData\\Local\\Temp\\.{1,20}\\.{1,20}\\.{1,20}/
		$s3 = /C:\\Users\\.{1,10}\\AppData\\Roaming\\Microsoft\\Windows\\.{1,20}\\.{1,20}\\.{1,20}\\.{1,20}/
		$s4 = /C:\\Users\\.{1,10}\\Desktop\\.{1,20}\\.{1,20}\\.{1,20}/
		$s5 = /C:\\Users\\.{1,10}\\AppData\\Local\\.{1,20}\\.{1,20}\\.{1,20}/
		// $s6 = /C:\\Users\\.{1,10}\\AppData\\Roaming\\Microsoft\\Windows\\Templates\\.{1,20}\\.{1,20}\\.{1,20}/
		$sid0 = "sigid:1733" fullword //	Tries to detect virtualization through RDTSC time measurements
		$sid2 = "sigid:620" fullword  //	Sample may be VM or Sandbox-aware. try analysis on a native machine
		$sigid1 = "sigid:430" fullword //PE file has an invalid certificate
		$sigid2 = "sigid:1545" fullword //Abnormal high CPU Usage
		$sigid3 = "sigid:198" fullword //Monitors certain registry keys / values for changes
		
    condition:
        $ftype and $s1 and ($s2 or $s3 or $s4 or $s5) and $sid0 and ($sid2 or ($sigid1 and $sigid2 and $sigid3))
	

}

