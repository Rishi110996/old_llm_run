$sigid7 = "sigid:862" fullword //Potential malicious VBS script found

condition:
$filetype and $cmd1 and $cmd2 and $st1 and $st2 and $st3 and $dQuery and $sigid1 and $sigid2 and $sigid3 and $sigid4 and $sigid5 and $sigid6 and $sigid7

