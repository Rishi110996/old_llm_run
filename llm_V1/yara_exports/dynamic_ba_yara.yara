rule HTA_Riskware_Cymulation_134200 : knownmalware 
 {
	meta:
		sigid = 134200
		date = "2025-04-23 13:15 PM"
		modified_date = "2025-04-23 18:08 PM"
		threatname = "HTA.Riskware.Cymulation"
		category = "Malware & Botnet"
		risk = 0
		
	strings:
$file=/staticgen:filetype:(hta|ps1|doc|exe|dll)/
$shell = "objShell = new ActiveXObject(\"WScript.Shell\")" nocase wide ascii
$cymulate1 = "CymulateCredsSteal" nocase wide ascii
$cymulate2 = "CymulateSMBWorm" nocase wide ascii
$cymulate3 = "CymulatedecodeBase64(" nocase wide ascii
$cymulate4 = "CymulateRansomware" nocase wide ascii
//$sig1="sigid:7021" fullword //Performs connections to IPs without corresponding DNS lookups
//$sig2="sigid:1337" fullword //Powershell drops PE file
//$sig3="sigid:1651" fullword //Compiles code to inject code
//$process = "(Get-Process \"Cymulate"

$sA1 = "Cymulate\\Agent\\AttacksLogs" nocase
$sA2 = "sigid:115" // Drops PE file
$sA4 = "sigid:1536" // Detected Cobalt Strike Beacon
$sB1 = "powershelldllinject" nocase

$cyma = "cym-" nocase

$cymb1= "\\CymulateStagelessMeterpreter.{0,4}exe" nocase // CymulateStagelessMeterpreter_64.exe
$cymb2= "\\CymulateStagelessMeterpreter.{0,4}pdb" nocase //CymulateStagelessMeterpreter.pdb
