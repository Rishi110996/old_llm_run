rule Java_PWS_Qealler_120872 : knownmalwareDS 
 {
	meta:
		sigid = 120872
		date = "2022-03-02 11:58 AM"
		threatname = "Java.PWS.Qealler"
		category = "Malware & Botnet"
		risk = 0
		
	strings:
$filetype = "staticgen:filetype:jar"

//seed is not changing in final payload -  session key
$seed = "uisdfysdgfbsdyufbsiybfsdyb733grfsudbfjh\n"
$payload_encryption_key = "bbb6fec5ebef0d93\n"

//function/class names in fnal payload
$payload_fn1 = "j.t.e.Main\n"
$payload_fn2 = "j.t.e.MainEx\n"
$payload_fn3 = "j/t/e/credential/softwares/SoftwareData\n"
$payload_fn4 = "ng:getSysInfo\n"
$payload_fn5 = "ng:pushCredentials\n"

//strings/functions/classes from second level packer just before final payload
$packer_str1 = "ng:PBKDF2WithHmacSHA1\n"
$packer_str2 = "com/sun/crypto/provider/PKCS5Padding"
$packer_str3 = "ng:decryptQ\n"
$packer_str4 = "q0b4.bootstrap.templates.Loader$1\n"
$packer_str5 = "q0b4.bootstrap.templates.Loader$1$1\n"
$packer_str6 = "ng:obfuscatedEntryList\n"

//strings from final payload activity
$str1 = "************************* OUTPUT ****************************"
$str2 = "ng:Credentials: "
$str3 = "ng:	Cookies: "
$str4 = "ng:SystemInfo: "
$str5 = "ng:globalIpAddress"
$str6 = "Will Connect to mozilla-based sqlite-db!!!"
$str7 = "ng:method::MozillaBased:decrypt!"
$str8 = "ng:ServerInfo"
$str9 = "ng:PYTHON"
$str10 = "ng:JNA_PLATFORM"
$str11 = "ng:CREDENTIAL_CMD"
$str12 = "ng:Q4_PASS_LIB"
$str13 = "ng:JPOWERSHELL"

condition:
$filetype and
(
  2 of ($payload_fn*) and
  (
    $seed or $payload_encryption_key
      or
    (4 of ($packer_str*))
      or
    (6 of ($str*))
  )
)
}

