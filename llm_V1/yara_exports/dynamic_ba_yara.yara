$delstring8="cymulate" nocase
$delstring9="TVqQAAMAAAAEAAAA"
$delstring10="$Base64EncodedEncryptedData"
$delstring12="defendnot" nocase
$vtresults="vt_result:detection:av_engine:"
$vtresultsmicrosoft="vt_result:detection:av_engine:Microsoft"
