		sigid = 124217
		date = "2025-04-22 04:01 AM"
		modified_date = "2025-04-22 04:03 AM"
		threatname = ""
		category = ""
		risk = 0
		hash="2F8ADFF19A0DFB1ECB9933A70E1DADFD"
	strings:
$type=/staticgen:filetype:(vbs|wsf)/
$process="processcreated:path:"
$sig1="sigid:839" fullword //Found WSH timer for Javascript or VBS script
$sig2="sigid:712" fullword //Javascript file with very long strings
$sig3="sigid:862" fullword //Potential malicious VBS script found
$dns="dnsquery:name"
$D1 = "dnsquery:name:tse1.mm.bing.net" //Extra dns
$blacklistreg="processcreated:path:C:\\Windows\\SysWOW64\\regsvr32.exe"
$blacklistmsh="processcreated:path:C:\\Windows\\SysWOW64\\mshta.exe"
$blacklistrun="processcreated:path:C:\\Windows\\System32\\rundll32.exe"
$blacklistpow="processcreated:path:C:\\Windows\\System32\\WindowsPowerShell"
$blacklistbit="processcreated:path:C:\\Windows\\System32\\bitsadmin.exe"
$blacklistasm=/processcreated:path:C:\\Windows\\Microsoft.NET\\Framework\\.{0,20}\\RegAsm.exe/
$blacklistsch="processcreated:path:C:\\Windows\\System32\\schtasks.exe"
$blacklistvss="processcreated:path:C:\\Windows\\System32\\vssadmin.exe"
$blacklistwmi="processcreated:path:C:\\Windows\\System32\\wbem\\WMIC.exe"
$blacklistsc="processcreated:path:C:\\Windows\\Microsoft.NET\\Framework\\v4.0.30319\\RegSvcs.exe"
$blacklist_signature16="sigid:356" fullword //Drops PE files to the startup folder
$blacklist_signature15="sigid:533" fullword //May use bcdedit to modify the Windows boot settings
$blacklist_signature1="sigid:11004" fullword //VT sig
$blacklist_signature2="sigid:1318" fullword //Suspended mode signature
$blacklist_signature4="sigid:154" fullword //Inject PE
$blacklist_signature5="sigid:441" fullword
$blacklist_signatures94="sigid:94" fullword
$blacklist_signatures304="sigid:304" fullword
$blacklist_signature6="sigid:914" fullword
$blacklist_signature7="sigid:231" fullword
$blacklist_signature8="sigid:232" fullword
$blacklist_signature10="sigid:895" fullword
$blacklist_signature11="sigid:252" fullword
$blacklist_sigid30="sigid:700" fullword
$blacklist_sigid31="sigid:158" fullword
$blacklist_sig1675="sigid:1675" fullword //Found Sandbox artifacts in file path
$blacklist_100="sigid:375" fullword //Sets file extension default program settings
$blacklist_101="sigid:191" fullword //Modifies the Window Firewall
$blacklist_102="sigid:259" fullword //Uses taskkill to terminate processes
$blacklist_snort="sigid:879" fullword //Snort IDS Alert for network traffic
$blacklist_cmd="sigid:644" fullword //Very long cmdline option found
$blacklist_sleepstring = /WScript\.Sleep\([1-9][0-9]{5,6}/ nocase
$blacklistmst="vt_result:detection:av_engine:Microsoft:"
$processex="processcreated:path:C:\\Program Files (x86)\\Internet Explorer\\iexplore.exe"
$blacklistnod32="vt_result:detection:av_engine:ESET-NOD32:"
$results="vt_result:detection:av_engine"
$blackliststr1 = "VGhpcyBwcm9ncmFtIGNhbm5vdCBiZSBydW4gaW4gRE9TIG1v"
$blackliststr = /WS(\#|\*|\&|\%|\$|\@|\!|\~|\^)cri(\#|\*|\&|\%|\$|\@|\!|\~|\^)pt\.Sh(\#|\*|\&|\%|\$|\@|\!|\~|\^)ell/

condition:
((not any of ($blacklist*) and not #results>=4 )) 
and (($type and $sig1 and $sig2 and #process<=5) or ($type and $sig1 and $sig2 and $sig3 and not $dns) or ($processex and $type and $process and $sig1 and $sig2 and $sig3 and #process==4))
and (not $dns or ($D1 and #dns == 1 ))
}

