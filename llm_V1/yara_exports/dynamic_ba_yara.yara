$s18 = "sigid:616" fullword //Connects to a pastebin service (likely for C&C)
condition:
  $s1 at 0 and $s2 and $s3 and $s4 and $s5 and $s6 and $s7 and $s8 and $s9 and $s10 and $s11 and $s12 and $s13 and $s14 and $s15 and $s16 and $s17 and $s18
}

