		threatname = "Detects ScreenConnect"
	strings:
		$ssr1 = "Bin/ScreenConnect"
		$ssr2 = "ScreenConnect.Client.dll"
		$str1 = "Reboot and Reconnect Safe Mode"
		$str2 = "asInvoker"
		$str3 = "ClickOnceRunner.pdb"
		$str4 = "DotNetServiceRunner.pdb"
		$str5 = "staticgen:filetype:exe"
		$str6 = "window:title:Launching Application"
		$str7 = "dnsquery:name"

		$sigid1 = "sigid:127" fullword   // Downloads files from web servers via HTTP
		$sigid2 = "sigid:11010" fullword // Sample sleeps for a long time (installer files shows these property).
		$sigid3 = "sigid:307" fullword  // Executes massive amount of sleeps in a loop
