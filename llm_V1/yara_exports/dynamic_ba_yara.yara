		$sigid3 = "sigid:1649"fullword //Hides that the sample has been downloaded from the Internet (zone.identifier)
		$new_sig1 = "sigid:7051" fullword //Found Malware Configuration
		$new_sig2 = "sigid:304" fullword  //Benign Windows Process Is Dropping New PE Files
		$sigid4 = "sigid:186" fullword //Maps a DLL or memory area into another process
		$sigid5 = "sigid:156" fullword //Creates a thread in another existing process (thread injection)
		$sigid6 = "sigid:231" fullword //Tries to harvest and steal browser information
		$sig_new = "sigid:127" fullword //Downloads files from web servers via HTTP
		
		$sigid_new2 = "sigid:1649" fullword //Hides That The Sample Has Been Downloaded From The Internet
		$sigid_new3 = "sigid:546" fullword //Creates Multiple Autostart Registry Keys
		$sigid_new4 = "sigid:523" fullword //Drops Files With A Non Matching File Extension
		
		$new_sigid1817 = "sigid:1817" fullword //Detected Osiris Trojan
		
condition:
		$filetype and ($new_sig1 or $new_sig2 or $sigid_new3) and ($sigid3 or $sig_new) and $sigid4 and ($sigid5 or $new_sigid1817) and (($sigid6 or $new_sig1) or ($sigid_new2 and $sigid_new4 or $sigid_new3))
}

