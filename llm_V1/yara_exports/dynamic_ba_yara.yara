rule Win32_SingleDNS5_Clean_135259 : knownclean 
 {
	meta:
		sigid = 135259
		date = "2025-08-12 10:24 AM"
		modified_date = "2025-08-12 10:25 AM"
		threatname = ""
		category = ""
		risk = 0
		
	strings:
$total="dnsquery:name:"
$vt="sigid:11004" fullword         //Known md5
$D1 = "dnsquery:name:tse1.mm.bing.net" //extra DNS
$dns1 = "dnsquery:name:publications.icao.int"
$dns2= "dnsquery:chart.apis.google.com"
$c3 = "sigid:249" fullword //Uses nslookup.exe to query domains
$dns3 = /dnsquery:name:.{7,15}\.in-addr\.arpa/
$dns4 = "dnsquery:name:prod.maxeoncorp.com"
$dns5= "dnsquery:name:mssql-137789-0.cloudclusters.net"
$dns6a= "dnsquery:name:usa.ishopforipsos.com"
$dns6b= "dnsquery:name:media09.research-cloud.com"
$dns7 = "dnsquery:name:mxr.mozilla.org"
$dns8 = "dnsquery:name:at-bay.binalyze.io"
$dns9 = "dnsquery:name:naturaldocs.org"
$auto=/dnsquery:name:.{1,50}\.autodesk.com/
$dns11 = /dnsquery:name:.{1,30}\.everilion\.com/ //for md5 ed48e05515761f5900c19253a184b61e
$dns12 = "dnsquery:name:api.fxblue.com"
$dns13 = "dnsquery:name:cdn.oneget.org"
$dns14 = "dnsquery:name:stcanalyticsdiy.pg.com"
$dns14b = "dnsquery:name:xlworks.net"
$dns14c = "dnsquery:name:bud1eusqlw01.sanmina.com"
$dns15=/dnsquery:name:.{1,50}\.capgemini.com/
$dnscdn="dnsquery:name:cdn.oneget.org"
$ps="staticgen:filetype:ps1" fullword
condition:
not $vt and 
(
 ($dns1 and #dns1+#D1==#total) or
 ($dns2 and #dns2+#D1==#total) or 
 ($c3 and $dns3 and #dns3+#D1==#total) or 
 ($dns4 and #dns4+#D1==#total) or 
($dns5 and #dns5+#D1==#total) or
($dns6a and $dns6b and #dns6a +#dns6b+#D1==#total) or
($dns7 and #dns7+#D1==#total) or
($dns8 and #dns8+#D1==#total) or
($dns9 and #dns9+#D1==#total) or 
($auto and $total and #total==#auto) or
($dns11 and #dns11+#D1==#total) or 
($dns12 and #dns12+#D1==#total) or
($dns13  and #dns13 ==#total) or
($dns14  and #dns14 ==#total) or
($dns14b  and #dns14b ==#total) or
($dns14c  and #dns14c ==#total)or
($dns15 and #dns15 ==#total) or ($dnscdn and $ps and #dnscdn==#total))
}

