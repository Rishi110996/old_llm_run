		sigid = 120849
		date = "2022-03-02 11:58 AM"
		threatname = ""
		category = ""
		risk = 0
		hash="F28E2E88076C13E212F8EA36C1491775"
	strings:
$file="staticgen:filetype:jar" fullword
$str1="sigid:11010" //sample sleeps for a long time in installers
$str2="sigid:318" //Runtime environment drops PE file

$signot="sigid:11004" // VT detection
$signot1="sigid:879" //Snort signature
$signot2="sigid:253" //Uses reg.exe to modify the Windows registry
$signot3="sigid:810" //Potential malicious VBS script found
$signot4="sigid:1303" //AdwindRAT
$signot5="dnsquery:name" //No DNS query
$signot6="sigid:7018" //AdwindRAT configuration
$signot7="sigid:7021" //Performs connections to IPs without corresponding DNS lookups
$signot8="sigid:522" //Detected TCP or UDP traffic on non-standard ports

condition:
($file and $str1 and $str2) and not ($signot or $signot1 or $signot2 or $signot3 or $signot4 or $signot5 or $signot6 or $signot7 or $signot8)
}

