rule Win32_Banker_Emotet_122463 : knownmalwareDS 
 {
	meta:
		sigid = 122463
		date = "2022-03-02 11:59 AM"
		threatname = "Win32.Banker.Emotet"
		category = "Malware & Botnet"
		risk = 0
		
	
strings:
$filetype1 = "staticgen:filetype:exe"
$filetype2 = "staticgen:filetype:dll"
$post = "http:header:POST"
$ref1 = /\x0d\x0aReferer:\s+http:\/\/((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)(\.)){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\//
$ref2 = /\x0d\x0aReferer:\s+((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)(\.)){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\//
$host = /\x0d\x0aHost:\s+((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)(\.)){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)/
$ua=  "Mozilla/4.0 (compatible; MSIE 7.0; Windows NT 10.0; WOW64; Trident/7.0; .NET4.0C; .NET4.0E; .NET CLR 2.0.50727; .NET CLR 3.0.30729; .NET CLR 3.5.30729)"
$boundry = "Content-Type: multipart/form-data; boundary=-------------"
condition:
($filetype1 or $filetype2) and ($post and $host and $ua and $boundry )
        and (
                ($ref2 and  ( uint32(@ref2+11) == uint32(@host+8)  ) )
                or
                ($ref1 and  ( uint32(@ref1+18) == uint32(@host+8)  ) )
            )


}

