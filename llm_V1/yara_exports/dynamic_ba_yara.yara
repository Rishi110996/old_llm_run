rule Win32_Backdoor_SDBbot_TA505_121427 : monitormode 
 {
	meta:
		sigid = 121427
		date = "2022-03-02 11:58 AM"
		threatname = "Win32.Backdoor.SDBBot"
		category = "Malware & Botnet"
		risk = 0
		author = "Sahil"
created_on = "02/07/2020"
filetype = "dll"
type = "APT|Backdoor"
version = "1.0"
description = "This rule is to detect SDBbot backdoor used in TA505"
hash1 = "8d9ed9db8ad7d6af8abc05f85f3d1dbe"
hash2 = "272f9daeef4632396d1a173ee3a31bcb"
hash3 = "ef7b806c45fce25b70d04ce253295110"
hash4 = "64d3cc1e49273d3356af736922c89dfa"
hash5 = "a66e9afbba9b0f014d0774070b59c79e"
hash6 = "e3f57d7d933d19d190ff27ec455875ac"
	strings:
$filetype = "staticgen:filetype:dll"
	
