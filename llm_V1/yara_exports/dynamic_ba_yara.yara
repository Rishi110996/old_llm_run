		$fdump3 = /filedump:path:C:\\.{0,100}\\files_\\screenshot/
		$f_oth_dmp1 = /filedump:path:C:\\.{0,100}\\_Files\\_Wallet\\/
		$f_oth_dmp2 = /filedump:path:C:\\.{0,100}\\_Files\\_Cookies\\/
		$url_pattern = /memstring:string:http:\/\/.{5,40}\/index.php/
		$sigid1 = "sigid:231" fullword //...Tries to harvest and steal browser information
		$sigid2 ="sigid:7038" fullword //...Found many strings related to Crypto-Wallets (likely being stolen)
	condition:
		$filetype and $fdump1 and $fdump2 and $fdump3 and $f_oth_dmp1 and $f_oth_dmp2 and $url_pattern and $sigid1 and $sigid2
}

