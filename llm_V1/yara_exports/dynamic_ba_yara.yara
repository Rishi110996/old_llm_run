rule Win32_Rawinput_Clean_123619 : knownclean 
 {
	meta:
		sigid = 123619
		date = "2025-06-16 07:15 AM"
		modified_date = "2025-06-16 11:37 AM"
		threatname = ""
		category = ""
		risk = 0
		hash="0CCCCFAAAF399B667DED0A2E8A4D4440"
	strings:
$type=/staticgen:filetype:(exe|dll).{0,3}/
$raw="sigid:310" fullword //Installs raw input device
$thread="sigid:908" fullword //Contain thread delay
$crash="sigid:81" fullword //One or more processes crash
$writewatch="sigid:1681" fullword //Allocates memory with a write watch
$largebinary="sigid:443" fullword //Stores large binary data
$suspicioustime="sigid:234" fullword //Binary contains a suspicious time stamp
$detectedtcp="sigid:522" fullword //Detected TCP or UDP traffic on non-standard ports
$VT="sigid:11004" fullword
$del1833="sigid:1833" fullword
$del1309="sigid:1309" fullword
$dns="dnsquery:name:"
$snort="sigid:879" fullword //Snort signature
$IP="sigid:7021" fullword //Performs connections to IPs without corresponding DNS lookups
$suspended="sigid:1318" //suspended mode signature
$inject="sigid:154"
$download="sigid:127" fullword //Downloads files from web servers via HTTP
$harvest="sigid:231" fullword //Tries to harvest and steal browser information
$tor="sigid:7005" fullword
$avcheck="sigid:699" fullword
$checkIP="sigid:77" fullword //Checks the public IP address of the machine
$dllName = /beacon.{0,6}\.dll/ nocase
$exportName = "ReflectiveLoader" nocase
$delstr1 = "ReverseShell"
$vtresults="vt_result:detection:av_engine:"
$vtresultsmicrosoft="vt_result:detection:av_engine:Microsoft"
$vtresultsnod32="vt_result:detection:av_engine:ESET-NOD32"
$delmain2 = /(mimikatz RPC communicator|%c%c%c%c%c%c%c%c%cMSSE-%d-server|hidcon:cmd \/c start|FH Manager)/
condition:
(not any of ($del*)) and ($type and $crash) and ($raw or $thread or $suspicioustime or $largebinary or $writewatch) and not ($dllName or $exportName or $checkIP or $avcheck or $tor or $detectedtcp or $VT or $dns or $snort or $IP or $suspended or $inject or $download or $harvest) and #vtresults<5 and not ($vtresultsmicrosoft or $vtresultsnod32)
}

