rule Python_RAT_SilentSync_139596 : knownmalware 
 {
	meta:
		sigid = 139596
		date = "2025-08-28 13:20 PM"
		modified_date = "2025-08-28 16:57 PM"
		threatname = "Python.RAT.SilentSync"
		category = "Malware & Botnet"
		risk = 0
		
	strings:
        $filetype = "staticgen:filetype:py"
        $s1 = "requests.get(f\"http://{b64decode('"
        $s2 = "Microsoft\\\\Windows\\\\Themes\\\\theme_helper.py"
        $s3 = "os.path.join(os.getenv(\"APPDATA\"),"
        $s4 = " RAT"
        $s5 = ":5000/archivo"
        $s6 = "make_archive(zip_path.replace(\""
        $s7 = "/tmp/screenshot.png\""
        $s8 = "Browser Data"
        $s9 = "cursor.execute(query)"
        $s10 = "CryptUnprotectData(encrypted_key"
        $s11 = "base64.b64decode(key_b64)[5:]"
        $s12 = "get_chrome_key"
        $s13 = "Sends a POST request."
        $sigid1 = "sigid:305" fullword //Creates an autostart registry key
        $sigid2 = "sigid:238" fullword //URLs found in memory or binary data
        $sigid3 = "sigid:337" fullword //Queries the volume information (name, serial number etc) of a device
        $sigid4 = "sigid:381" fullword //Disables application error messsages (SetErrorMode)
        $sigid5 = "sigid:7021" fullword //Connects to IPs without corresponding DNS lookups
        $sigid6 = "sigid:121" fullword //Enumerates the file system

    condition:
        $filetype at 0 and
        $s1 and $s2 and $s3 and $s4 and
        $s5 and $s6 and $s7 and $s8 and
        $s9 and $s10 and $s11 and $s12 and $s13 and $sigid1 and $sigid2 and $sigid3 and $sigid4 and $sigid5 and $sigid6
}

rule PS_GenSleep_Clean_134883 : knownclean 
 {
	meta:
		sigid = 134883
		date = "2025-08-27 08:35 AM"
		modified_date = "2025-08-27 08:36 AM"
		threatname = ""
		category = ""
		risk = 0
		
	strings:
$type="staticgen:filetype:ps1"
$sig641="sigid:641" fullword
$del7021="sigid:7021" fullword
$del11004="sigid:11004" fullword
$del879="sigid:879" fullword
$del913="sigid:913" fullword
$del1620="sigid:1620" fullword
$del522="sigid:522" fullword
$del154="sigid:154" fullword
$del616="sigid:616" fullword
$del1976="sigid:1976" fullword
$del1816="sigid:1816" fullword
$del1737 = "sigid:1737"fullword //Queries port and connector information
$delprocess=/processcreated:path:.{1,100}(bitsadmin|gpresult|RegAsm|RegSvcs|wscript|vgtray|QQPCTray|attrib|shutdown|taskkill|regsvr32|vssadmin|bcdedit|kxetray)/ nocase
