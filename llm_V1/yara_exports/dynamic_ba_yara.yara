		modified_date = "2025-08-04 12:41 PM"
		threatname = "Win32.PWS.Lumma"
		category = "Malware & Botnet"
		risk = 100
		
	strings:
		$ft = "staticgen:filetype:exe" fullword
		$s1 = /cmd.exe\" \/c copy [A-z0-9]{1,20}.gif/
		$s2 = /filedump:path:C:\\Users\\PJones\\AppData\\Local\\Temp\\[A-z0-9]{1,20}.gif/
		$s3 = "steamcommunity"
		$s4 = "telegram"

		$sig1 ="sigid:231" fullword //Tries to harvest and steal browser information
		$sig2 ="sigid:232" fullword //Tries to harvest and steal FTP login credentials
		$sig3 ="sigid:699" fullword //Checks if anti-virus program is installed
		$sig4 ="sigid:1699" fullword//Tries to steal Crypto Currency Wallets

condition:
		$ft and $s1 and $s2 and $s3 and $s4 and $sig1 and $sig2 and $sig3 and $sig4
}


