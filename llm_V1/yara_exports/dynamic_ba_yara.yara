rule Win64_Injection_chromeinject_139583 : monitormode 
 {
	meta:
		sigid = 139583
		date = "2025-08-20 09:47 AM"
		modified_date = "2025-08-20 12:07 PM"
		threatname = "Win64.Injection.chromeinject"
		category = "Malware & Botnet"
		risk = 0
		
	strings:
$filetype = "staticgen:filetype:exe"
        $s1 = "terminated by injector." ascii wide
        $s2 = "Enable verbose debug output from the injector" nocase ascii wide
        $s3 = "chrome_inject.exe [options] <chrome|brave|edge>" ascii wide
        $s4 = "v0.14.1 by @xaitax" ascii wide
        $s5 = "Direct Syscall-Based Reflective Hollowing" ascii wide
        $s6 = "Chrome App-Bound Encryption Decryption" ascii wide
        $s7 = "Architecture mismatch. Injector is" ascii wide
        $s8 = "ReflectiveLoader found at file offset:" ascii wide
        $s9 = "--verbose" ascii wide
        $s10  = "sigid:200027" fullword // Lokibot malware found
        $s11 = "sigid:418"    fullword // Submission file is bigger than most known malware samples
        $s12 = "sigid:419"    fullword // PE file has a high image base, often used for DLLs
        $s13 = "sigid:410"    fullword // PE file has a big raw section

    condition:
        $filetype at 0 and 
        $s1 and $s2 and $s3 and $s4 and $s5 and $s6 and $s7 and $s8 and $s9 and $s10 and $s11 and $s12 and $s13
}

