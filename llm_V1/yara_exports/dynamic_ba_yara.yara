rule Win32_CoinMiner_Gen_132810 : knownmalware40 
 {
	meta:
		sigid = 132810
		date = "2024-07-04 19:19 PM"
		threatname = "Win32.Coinminer.Gen"
		category = "Malware & Botnet"
		risk = 0
		hash="87AA5F3F514AF2B9EF28DB9F092F3249"
	strings:
		$filetype = /staticgen:filetype:(exe|dll)/
		$cryptocurrency1 = "Exodus"
		$cryptocurrency2 = "GreenAddress"
		$cryptocurrency3 = "Monero"
		$cryptocurrency4 = "WalletWasabi"
		$cryptocurrency5 = "Bitcoin"
		$cryptocurrency6 = "Ethereum"

		
		$sigid1 = "sigid:425" fullword		//PE File Has A Writeable .Text Section
		$sigid3 = "sigid:11009" fullword	//Drops PE Files In Application Program Directory But Not Started Or Loaded
		$sigid4 = "sigid:116" fullword		//Dropped PE Files Which Have Not Been Started Or Loaded
		$netsigid1 = "sigid:625" fullword		//Uses HTTPS
		$netsigid2 = "sigid:624" fullword		//Uses HTTPS for network communication
		$netsigid3 = "sigid:1020" fullword		//Uses HTTP to connect to Internet
		
	condition:
		$filetype and 
		$sigid1 and 
		($sigid3 or $sigid4) and 
		($netsigid1 or $netsigid2 or $netsigid3) and 
		any of ($cryptocurrency*)
}

